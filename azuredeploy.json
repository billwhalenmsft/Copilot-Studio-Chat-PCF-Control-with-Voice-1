{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "2.0.0.0",
  "metadata": {
    "description": "Deploys the full speech proxy stack for Copilot Chat PCF Control with Voice: Azure Speech, Azure OpenAI (with TTS deployment), Function App with managed identity, RBAC role assignments, Storage Account, Application Insights, and App Service Plan."
  },
  "parameters": {
    "resourcePrefix": {
      "type": "string",
      "minLength": 3,
      "maxLength": 15,
      "metadata": {
        "description": "A unique prefix (3-15 chars, lowercase letters/numbers) used to name all resources. Example: 'outsales' creates 'outsales-speech', 'outsales-openai', 'outsales-proxy', etc."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for Speech Services, Function App, and supporting resources. Must support Speech Services."
      }
    },
    "openAILocation": {
      "type": "string",
      "defaultValue": "northcentralus",
      "allowedValues": [
        "australiaeast",
        "brazilsouth",
        "canadaeast",
        "eastus",
        "eastus2",
        "francecentral",
        "germanywestcentral",
        "japaneast",
        "koreacentral",
        "northcentralus",
        "norwayeast",
        "polandcentral",
        "southafricanorth",
        "southcentralus",
        "southindia",
        "swedencentral",
        "switzerlandnorth",
        "uksouth",
        "westeurope",
        "westus",
        "westus3"
      ],
      "metadata": {
        "description": "Azure region for OpenAI. Must support Azure OpenAI Service and TTS model deployments."
      }
    },
    "openAIModelName": {
      "type": "string",
      "defaultValue": "gpt-4o-mini",
      "allowedValues": [
        "gpt-4o-mini",
        "gpt-4o",
        "gpt-4",
        "gpt-35-turbo"
      ],
      "metadata": {
        "description": "The OpenAI chat model to deploy. gpt-4o-mini is recommended for cost-effective general use."
      }
    },
    "openAIModelVersion": {
      "type": "string",
      "defaultValue": "2024-07-18",
      "metadata": {
        "description": "Chat model version. Default '2024-07-18' for gpt-4o-mini."
      }
    },
    "openAIDeploymentCapacity": {
      "type": "int",
      "defaultValue": 10,
      "minValue": 1,
      "maxValue": 100,
      "metadata": {
        "description": "Chat deployment capacity in thousands of tokens per minute (TPM)."
      }
    },
    "ttsModelName": {
      "type": "string",
      "defaultValue": "tts",
      "allowedValues": [
        "tts",
        "tts-hd"
      ],
      "metadata": {
        "description": "OpenAI TTS model to deploy. 'tts' = standard quality, 'tts-hd' = higher quality."
      }
    },
    "ttsModelVersion": {
      "type": "string",
      "defaultValue": "001",
      "metadata": {
        "description": "TTS model version. Use '001' for current TTS models."
      }
    },
    "ttsDeploymentCapacity": {
      "type": "int",
      "defaultValue": 1,
      "minValue": 1,
      "maxValue": 100,
      "metadata": {
        "description": "TTS deployment capacity (requests per minute). TTS quotas are typically low; start with 1."
      }
    },
    "speechServiceSku": {
      "type": "string",
      "defaultValue": "S0",
      "allowedValues": [
        "F0",
        "S0"
      ],
      "metadata": {
        "description": "Speech Services pricing tier. F0 = Free (limited), S0 = Standard."
      }
    },
    "functionAppSku": {
      "type": "string",
      "defaultValue": "Y1",
      "allowedValues": [
        "Y1",
        "B1",
        "S1"
      ],
      "metadata": {
        "description": "App Service Plan SKU for the Function App. Y1 = Consumption (pay-per-use, cold starts). B1/S1 = dedicated (supports Always On, no cold starts)."
      }
    },
    "functionApiKey": {
      "type": "securestring",
      "metadata": {
        "description": "A strong API key used to authenticate client requests to the speech proxy (sent via x-api-key header). Generate with: [guid]::NewGuid().ToString('N').Substring(0,32)"
      }
    }
  },
  "variables": {
    "speechAccountName": "[concat(toLower(parameters('resourcePrefix')), '-speech')]",
    "openAIAccountName": "[concat(toLower(parameters('resourcePrefix')), '-openai')]",
    "openAIDeploymentName": "[parameters('openAIModelName')]",
    "ttsDeploymentName": "[parameters('ttsModelName')]",
    "functionAppName": "[concat('func-speech-proxy-', toLower(parameters('resourcePrefix')))]",
    "appServicePlanName": "[concat(toLower(parameters('resourcePrefix')), '-plan')]",
    "storageAccountName": "[concat(toLower(replace(parameters('resourcePrefix'), '-', '')), 'stg')]",
    "appInsightsName": "[concat(toLower(parameters('resourcePrefix')), '-insights')]",
    "logAnalyticsName": "[concat(toLower(parameters('resourcePrefix')), '-logs')]",
    "isDedicatedPlan": "[not(equals(parameters('functionAppSku'), 'Y1'))]",
    "cognitiveServicesUserRoleId": "a97b65f3-24c7-4388-baec-2e87135dc908"
  },
  "resources": [
    {
      "type": "Microsoft.CognitiveServices/accounts",
      "apiVersion": "2024-10-01",
      "name": "[variables('speechAccountName')]",
      "location": "[parameters('location')]",
      "kind": "SpeechServices",
      "sku": {
        "name": "[parameters('speechServiceSku')]"
      },
      "properties": {
        "customSubDomainName": "[variables('speechAccountName')]",
        "publicNetworkAccess": "Enabled"
      },
      "tags": {
        "solution": "CopilotChatPCF",
        "component": "SpeechServices"
      }
    },
    {
      "type": "Microsoft.CognitiveServices/accounts",
      "apiVersion": "2024-10-01",
      "name": "[variables('openAIAccountName')]",
      "location": "[parameters('openAILocation')]",
      "kind": "OpenAI",
      "sku": {
        "name": "S0"
      },
      "properties": {
        "customSubDomainName": "[variables('openAIAccountName')]",
        "publicNetworkAccess": "Enabled"
      },
      "tags": {
        "solution": "CopilotChatPCF",
        "component": "AzureOpenAI"
      }
    },
    {
      "type": "Microsoft.CognitiveServices/accounts/deployments",
      "apiVersion": "2024-10-01",
      "name": "[concat(variables('openAIAccountName'), '/', variables('openAIDeploymentName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts', variables('openAIAccountName'))]"
      ],
      "sku": {
        "name": "GlobalStandard",
        "capacity": "[parameters('openAIDeploymentCapacity')]"
      },
      "properties": {
        "model": {
          "format": "OpenAI",
          "name": "[parameters('openAIModelName')]",
          "version": "[parameters('openAIModelVersion')]"
        },
        "raiPolicyName": "Microsoft.DefaultV2"
      }
    },
    {
      "type": "Microsoft.CognitiveServices/accounts/deployments",
      "apiVersion": "2024-10-01",
      "name": "[concat(variables('openAIAccountName'), '/', variables('ttsDeploymentName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts', variables('openAIAccountName'))]",
        "[resourceId('Microsoft.CognitiveServices/accounts/deployments', variables('openAIAccountName'), variables('openAIDeploymentName'))]"
      ],
      "sku": {
        "name": "Standard",
        "capacity": "[parameters('ttsDeploymentCapacity')]"
      },
      "properties": {
        "model": {
          "format": "OpenAI",
          "name": "[parameters('ttsModelName')]",
          "version": "[parameters('ttsModelVersion')]"
        }
      }
    },
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2022-10-01",
      "name": "[variables('logAnalyticsName')]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": {
          "name": "PerGB2018"
        },
        "retentionInDays": 30
      },
      "tags": {
        "solution": "CopilotChatPCF",
        "component": "Monitoring"
      }
    },
    {
      "type": "Microsoft.Insights/components",
      "apiVersion": "2020-02-02",
      "name": "[variables('appInsightsName')]",
      "location": "[parameters('location')]",
      "kind": "web",
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsName'))]"
      ],
      "properties": {
        "Application_Type": "web",
        "WorkspaceResourceId": "[resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsName'))]"
      },
      "tags": {
        "solution": "CopilotChatPCF",
        "component": "Monitoring"
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2023-05-01",
      "name": "[variables('storageAccountName')]",
      "location": "[parameters('location')]",
      "kind": "StorageV2",
      "sku": {
        "name": "Standard_LRS"
      },
      "properties": {
        "supportsHttpsTrafficOnly": true,
        "minimumTlsVersion": "TLS1_2",
        "allowBlobPublicAccess": false
      },
      "tags": {
        "solution": "CopilotChatPCF",
        "component": "Storage"
      }
    },
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2023-12-01",
      "name": "[variables('appServicePlanName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "[parameters('functionAppSku')]"
      },
      "properties": {
        "reserved": false
      },
      "tags": {
        "solution": "CopilotChatPCF",
        "component": "Compute"
      }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2023-12-01",
      "name": "[variables('functionAppName')]",
      "location": "[parameters('location')]",
      "kind": "functionapp",
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', variables('appServicePlanName'))]",
        "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]",
        "[resourceId('Microsoft.Insights/components', variables('appInsightsName'))]",
        "[resourceId('Microsoft.CognitiveServices/accounts', variables('speechAccountName'))]",
        "[resourceId('Microsoft.CognitiveServices/accounts', variables('openAIAccountName'))]"
      ],
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('appServicePlanName'))]",
        "httpsOnly": true,
        "siteConfig": {
          "alwaysOn": "[variables('isDedicatedPlan')]",
          "minTlsVersion": "1.2",
          "nodeVersion": "~20",
          "cors": {
            "allowedOrigins": [
              "*"
            ]
          },
          "appSettings": [
            {
              "name": "AzureWebJobsStorage",
              "value": "[concat('DefaultEndpointsProtocol=https;AccountName=', variables('storageAccountName'), ';EndpointSuffix=', environment().suffixes.storage, ';AccountKey=', listKeys(resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName')), '2023-05-01').keys[0].value)]"
            },
            {
              "name": "WEBSITE_CONTENTAZUREFILECONNECTIONSTRING",
              "value": "[concat('DefaultEndpointsProtocol=https;AccountName=', variables('storageAccountName'), ';EndpointSuffix=', environment().suffixes.storage, ';AccountKey=', listKeys(resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName')), '2023-05-01').keys[0].value)]"
            },
            {
              "name": "WEBSITE_CONTENTSHARE",
              "value": "[toLower(variables('functionAppName'))]"
            },
            {
              "name": "FUNCTIONS_EXTENSION_VERSION",
              "value": "~4"
            },
            {
              "name": "FUNCTIONS_WORKER_RUNTIME",
              "value": "node"
            },
            {
              "name": "WEBSITE_NODE_DEFAULT_VERSION",
              "value": "~20"
            },
            {
              "name": "APPINSIGHTS_INSTRUMENTATIONKEY",
              "value": "[reference(resourceId('Microsoft.Insights/components', variables('appInsightsName')), '2020-02-02').InstrumentationKey]"
            },
            {
              "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
              "value": "[reference(resourceId('Microsoft.Insights/components', variables('appInsightsName')), '2020-02-02').ConnectionString]"
            },
            {
              "name": "AZURE_SPEECH_REGION",
              "value": "[parameters('location')]"
            },
            {
              "name": "AZURE_SPEECH_RESOURCE_NAME",
              "value": "[variables('speechAccountName')]"
            },
            {
              "name": "AZURE_OPENAI_ENDPOINT",
              "value": "[reference(resourceId('Microsoft.CognitiveServices/accounts', variables('openAIAccountName')), '2024-10-01').endpoint]"
            },
            {
              "name": "AZURE_OPENAI_DEPLOYMENT",
              "value": "[variables('ttsDeploymentName')]"
            },
            {
              "name": "FUNCTION_API_KEY",
              "value": "[parameters('functionApiKey')]"
            }
          ]
        }
      },
      "tags": {
        "solution": "CopilotChatPCF",
        "component": "SpeechProxy"
      }
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(resourceId('Microsoft.CognitiveServices/accounts', variables('speechAccountName')), variables('functionAppName'), variables('cognitiveServicesUserRoleId'))]",
      "scope": "[concat('Microsoft.CognitiveServices/accounts/', variables('speechAccountName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', variables('functionAppName'))]",
        "[resourceId('Microsoft.CognitiveServices/accounts', variables('speechAccountName'))]"
      ],
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('cognitiveServicesUserRoleId'))]",
        "principalId": "[reference(resourceId('Microsoft.Web/sites', variables('functionAppName')), '2023-12-01', 'Full').identity.principalId]",
        "principalType": "ServicePrincipal"
      }
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(resourceId('Microsoft.CognitiveServices/accounts', variables('openAIAccountName')), variables('functionAppName'), variables('cognitiveServicesUserRoleId'))]",
      "scope": "[concat('Microsoft.CognitiveServices/accounts/', variables('openAIAccountName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', variables('functionAppName'))]",
        "[resourceId('Microsoft.CognitiveServices/accounts', variables('openAIAccountName'))]"
      ],
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('cognitiveServicesUserRoleId'))]",
        "principalId": "[reference(resourceId('Microsoft.Web/sites', variables('functionAppName')), '2023-12-01', 'Full').identity.principalId]",
        "principalType": "ServicePrincipal"
      }
    }
  ],
  "outputs": {
    "speechProxyEndpoint": {
      "type": "string",
      "value": "[concat('https://', reference(resourceId('Microsoft.Web/sites', variables('functionAppName')), '2023-12-01').defaultHostName)]",
      "metadata": {
        "description": "Set this as the 'SpeechProxyEndpoint' property on the PCF control in Power Apps."
      }
    },
    "speechProxyApiKey": {
      "type": "string",
      "value": "[parameters('functionApiKey')]",
      "metadata": {
        "description": "Set this as the 'SpeechProxyApiKey' property on the PCF control in Power Apps."
      }
    },
    "speechRegion": {
      "type": "string",
      "value": "[parameters('location')]",
      "metadata": {
        "description": "Set this as the 'SpeechRegion' property on the PCF control in Power Apps."
      }
    },
    "openAIEndpoint": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.CognitiveServices/accounts', variables('openAIAccountName')), '2024-10-01').endpoint]",
      "metadata": {
        "description": "Set this as the 'OpenAIEndpoint' property on the PCF control in Power Apps."
      }
    },
    "openAIDeploymentName": {
      "type": "string",
      "value": "[variables('ttsDeploymentName')]",
      "metadata": {
        "description": "Set this as the 'OpenAIDeployment' property on the PCF control in Power Apps."
      }
    },
    "functionAppName": {
      "type": "string",
      "value": "[variables('functionAppName')]",
      "metadata": {
        "description": "The Azure Function App name. Deploy the speech-proxy code to this app with: az functionapp deployment source config-zip"
      }
    },
    "functionAppPrincipalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Web/sites', variables('functionAppName')), '2023-12-01', 'Full').identity.principalId]",
      "metadata": {
        "description": "The managed identity principal ID of the Function App (for troubleshooting RBAC)."
      }
    },
    "speechResourceName": {
      "type": "string",
      "value": "[variables('speechAccountName')]",
      "metadata": {
        "description": "The Azure Speech Services resource name (custom domain enabled)."
      }
    },
    "openAIResourceName": {
      "type": "string",
      "value": "[variables('openAIAccountName')]",
      "metadata": {
        "description": "The Azure OpenAI resource name."
      }
    },
    "appInsightsName": {
      "type": "string",
      "value": "[variables('appInsightsName')]",
      "metadata": {
        "description": "Application Insights resource for monitoring the speech proxy."
      }
    }
  }
}
