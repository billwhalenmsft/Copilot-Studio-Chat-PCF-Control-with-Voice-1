{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "Deploys Azure Speech Services and Azure OpenAI resources for the Copilot Chat PCF Control with Voice."
  },
  "parameters": {
    "resourcePrefix": {
      "type": "string",
      "minLength": 3,
      "maxLength": 15,
      "metadata": {
        "description": "A unique prefix (3-15 chars, lowercase letters/numbers) used to name all resources. Example: 'contoso' creates 'contoso-speech' and 'contoso-openai'."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for Speech Services. Must support Speech Services. Common: eastus, westus2, westeurope."
      }
    },
    "openAILocation": {
      "type": "string",
      "defaultValue": "eastus2",
      "allowedValues": [
        "australiaeast",
        "brazilsouth",
        "canadaeast",
        "eastus",
        "eastus2",
        "francecentral",
        "germanywestcentral",
        "japaneast",
        "koreacentral",
        "northcentralus",
        "norwayeast",
        "polandcentral",
        "southafricanorth",
        "southcentralus",
        "southindia",
        "swedencentral",
        "switzerlandnorth",
        "uksouth",
        "westeurope",
        "westus",
        "westus3"
      ],
      "metadata": {
        "description": "Azure region for OpenAI. Must support Azure OpenAI Service. Default: eastus2."
      }
    },
    "openAIModelName": {
      "type": "string",
      "defaultValue": "gpt-4o-mini",
      "allowedValues": [
        "gpt-4o-mini",
        "gpt-4o",
        "gpt-4",
        "gpt-35-turbo"
      ],
      "metadata": {
        "description": "The OpenAI model to deploy. gpt-4o-mini is recommended for cost-effective TTS and general use."
      }
    },
    "openAIModelVersion": {
      "type": "string",
      "defaultValue": "2024-07-18",
      "metadata": {
        "description": "Model version to deploy. Default '2024-07-18' for gpt-4o-mini. Check Azure docs for available versions."
      }
    },
    "openAIDeploymentCapacity": {
      "type": "int",
      "defaultValue": 10,
      "minValue": 1,
      "maxValue": 100,
      "metadata": {
        "description": "Deployment capacity in thousands of tokens per minute (TPM). Default: 10K TPM. Increase for higher throughput."
      }
    },
    "speechServiceSku": {
      "type": "string",
      "defaultValue": "S0",
      "allowedValues": [
        "F0",
        "S0"
      ],
      "metadata": {
        "description": "Speech Services pricing tier. F0 = Free (limited), S0 = Standard (pay-as-you-go)."
      }
    }
  },
  "variables": {
    "speechAccountName": "[concat(toLower(parameters('resourcePrefix')), '-speech')]",
    "openAIAccountName": "[concat(toLower(parameters('resourcePrefix')), '-openai')]",
    "openAIDeploymentName": "[parameters('openAIModelName')]"
  },
  "resources": [
    {
      "type": "Microsoft.CognitiveServices/accounts",
      "apiVersion": "2024-10-01",
      "name": "[variables('speechAccountName')]",
      "location": "[parameters('location')]",
      "kind": "SpeechServices",
      "sku": {
        "name": "[parameters('speechServiceSku')]"
      },
      "properties": {
        "customSubDomainName": "[variables('speechAccountName')]",
        "publicNetworkAccess": "Enabled"
      },
      "tags": {
        "solution": "CopilotChatPCF",
        "component": "SpeechServices"
      }
    },
    {
      "type": "Microsoft.CognitiveServices/accounts",
      "apiVersion": "2024-10-01",
      "name": "[variables('openAIAccountName')]",
      "location": "[parameters('openAILocation')]",
      "kind": "OpenAI",
      "sku": {
        "name": "S0"
      },
      "properties": {
        "customSubDomainName": "[variables('openAIAccountName')]",
        "publicNetworkAccess": "Enabled"
      },
      "tags": {
        "solution": "CopilotChatPCF",
        "component": "AzureOpenAI"
      }
    },
    {
      "type": "Microsoft.CognitiveServices/accounts/deployments",
      "apiVersion": "2024-10-01",
      "name": "[concat(variables('openAIAccountName'), '/', variables('openAIDeploymentName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts', variables('openAIAccountName'))]"
      ],
      "sku": {
        "name": "GlobalStandard",
        "capacity": "[parameters('openAIDeploymentCapacity')]"
      },
      "properties": {
        "model": {
          "format": "OpenAI",
          "name": "[parameters('openAIModelName')]",
          "version": "[parameters('openAIModelVersion')]"
        },
        "raiPolicyName": "Microsoft.DefaultV2"
      }
    }
  ],
  "outputs": {
    "speechKey": {
      "type": "string",
      "value": "[listKeys(resourceId('Microsoft.CognitiveServices/accounts', variables('speechAccountName')), '2024-10-01').key1]",
      "metadata": {
        "description": "Copy this value to the 'bw_SpeechKey' environment variable in your Dynamics 365 environment."
      }
    },
    "speechRegion": {
      "type": "string",
      "value": "[parameters('location')]",
      "metadata": {
        "description": "Copy this value to the 'bw_SpeechRegion' environment variable in your Dynamics 365 environment."
      }
    },
    "openAIEndpoint": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.CognitiveServices/accounts', variables('openAIAccountName')), '2024-10-01').endpoint]",
      "metadata": {
        "description": "Copy this value to the 'bw_OpenAIEndpoint' environment variable in your Dynamics 365 environment."
      }
    },
    "openAIKey": {
      "type": "string",
      "value": "[listKeys(resourceId('Microsoft.CognitiveServices/accounts', variables('openAIAccountName')), '2024-10-01').key1]",
      "metadata": {
        "description": "Copy this value to the 'bw_OpenAIKey' environment variable in your Dynamics 365 environment."
      }
    },
    "openAIDeploymentName": {
      "type": "string",
      "value": "[variables('openAIDeploymentName')]",
      "metadata": {
        "description": "Copy this value to the 'bw_OpenAIDeployment' environment variable in your Dynamics 365 environment."
      }
    },
    "openAIResourceName": {
      "type": "string",
      "value": "[variables('openAIAccountName')]",
      "metadata": {
        "description": "The name of the Azure OpenAI resource created."
      }
    },
    "speechResourceName": {
      "type": "string",
      "value": "[variables('speechAccountName')]",
      "metadata": {
        "description": "The name of the Azure Speech Services resource created."
      }
    }
  }
}
